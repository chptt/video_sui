# App Configuration
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Sui Configuration
NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_SUI_RPC_URL=https://fullnode.testnet.sui.io:443
NEXT_PUBLIC_PACKAGE_ID=0xdfe4c53514e2c5889d44579e2b7c91d0fe1ce480e2d53e99ad70901170a34182
NEXT_PUBLIC_PLATFORM_TREASURY_ADDRESS=0x5f7f9dea08479bdaa5c2d10297a1d49aa2da2c245f40ce9191bdbabe77e94245
NEXT_PUBLIC_REGISTRY_ID=0x56bee34a6afaef78b8d20893c869c8d00a66326d8071be9ef55af7adbea7f903
NEXT_PUBLIC_PLATFORM_CONFIG_ID=0x0febdb9671a669f1d1aa30af7edd5dfc1247c064cf06f9ca8a1fa3ec0cb9c0b1

# Google OAuth (for zkLogin)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/auth/zklogin/callback

# Security Secrets (generate new ones using `npm run gen:secrets`)
JWT_SECRET=your-jwt-secret
ZKLOGIN_SALT_SECRET=your-zklogin-salt-secret
ENCRYPTION_MASTER_KEY=your-encryption-master-key

# Pinata (optional, though we use on-chain storage now)
PINATA_JWT=your-pinata-jwt
PINATA_GATEWAY_URL=https://your-pinata-gateway.pinata.cloud

# Platform Configuration
PLATFORM_FEE_PERCENTAGE=10
VIDEO_REVENUE_CAP_USD=20
SUI_USD_FALLBACK=1.5
ETH_USD_FALLBACK=3000

# Admin Configuration
ADMIN_EMAIL=admin@example.com

# Development Only
ALLOW_MOCK_PAYMENT=false
